{
  "name": "life-index-gui",
  "private": false,
  "license": "AGPL-3.0-only",
  "version": "0.5.1",
  "type": "module",
  "scripts": {
    "predev": "node scripts/require-dev-env.mjs --command \"npm run dev\"",
    "dev": "vite",
    "dev:backend": "node scripts/dev-backend.mjs",
    "predev:all": "node scripts/require-dev-env.mjs --command \"npm run dev:all\"",
    "dev:all": "concurrently \"npm run dev:backend\" \"vite --host 127.0.0.1\"",
    "prebuild": "node scripts/require-dev-env.mjs --command \"npm run build\"",
    "build": "tsc -b && vite build",
    "prepreview": "node scripts/require-dev-env.mjs --command \"npm run preview\"",
    "preview": "vite preview",
    "prelint": "node scripts/require-dev-env.mjs --command \"npm run lint\"",
    "lint": "eslint .",
    "premobile:acceptance": "node scripts/require-dev-env.mjs --command \"npm run mobile:acceptance\"",
    "mobile:acceptance": "npm run build && node scripts/mobile-acceptance-server.mjs",
    "pretest": "node scripts/require-dev-env.mjs --command \"npm run test\"",
    "test": "node scripts/font-runtime.test.mjs && node scripts/run-vitest.mjs",
    "pretest:coverage": "node scripts/require-dev-env.mjs --command \"npm run test:coverage\"",
    "test:coverage": "node scripts/run-vitest.mjs --coverage.enabled --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reportsDirectory=.tmp/coverage",
    "test:mobile-acceptance-server": "node scripts/mobile-acceptance-server.test.mjs",
    "test:agent-ops-stack": "node scripts/python-interpreter.test.mjs && node scripts/agent-ops-stack.test.mjs && node scripts/sync-skill.test.mjs && node scripts/gui-upgrade-atom.test.mjs",
    "pretest:watch": "node scripts/require-dev-env.mjs --command \"npm run test:watch\"",
    "test:watch": "vitest",
    "preverify-stack": "node scripts/require-dev-env.mjs --command \"npm run verify-stack\"",
    "verify-stack": "node scripts/verify-stack.mjs",
    "stop-all": "node scripts/stop-all.mjs",
    "sync-skill": "node scripts/sync-skill.mjs",
    "remote-link:start": "node scripts/remote-link.mjs start",
    "remote-link:status": "node scripts/remote-link.mjs status",
    "remote-link:stop": "node scripts/remote-link.mjs stop",
    "gui-upgrade:plan": "node scripts/gui-upgrade.mjs --plan --json",
    "gui-upgrade:apply": "node scripts/gui-upgrade.mjs --apply --json",
    "presmoke:e2e": "node scripts/require-dev-env.mjs --command \"npm run smoke:e2e\"",
    "smoke:e2e": "node scripts/smoke-e2e.mjs"
  },
  "dependencies": {
    "@fontsource/material-symbols-outlined": "5.3.0",
    "@fontsource/material-symbols-rounded": "5.3.0",
    "@nivo/core": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@tanstack/react-query": "^5.75.0",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.5",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^10.1.0",
    "motion": "^11.18.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-router": "^7.6.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "3.2.6",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.3.0",
    "vitest": "^3.0.0"
  }
}
