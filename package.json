{
  "name": "life-index-gui",
  "private": false,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "node scripts/dev-backend.mjs",
    "dev:all": "concurrently \"npm run dev:backend\" \"vite --host 127.0.0.1\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "mobile:acceptance": "npm run build && node scripts/mobile-acceptance-server.mjs",
    "test": "node scripts/run-vitest.mjs",
    "test:mobile-acceptance-server": "node scripts/mobile-acceptance-server.test.mjs",
    "test:agent-ops-stack": "node scripts/python-interpreter.test.mjs && node scripts/agent-ops-stack.test.mjs",
    "test:watch": "vitest",
    "verify-stack": "node scripts/verify-stack.mjs",
    "stop-all": "node scripts/stop-all.mjs",
    "remote-link:start": "node scripts/remote-link.mjs start",
    "remote-link:status": "node scripts/remote-link.mjs status",
    "remote-link:stop": "node scripts/remote-link.mjs stop",
    "smoke:e2e": "node scripts/smoke-e2e.mjs"
  },
  "dependencies": {
    "@nivo/core": "^0.99.0",
    "@nivo/pie": "^0.99.0",
    "@tanstack/react-query": "^5.75.0",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.5",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^10.1.0",
    "motion": "^11.18.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-router": "^7.6.0",
    "recharts": "^3.8.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^6.3.0",
    "vitest": "^3.0.0"
  },
  "license": "Apache-2.0"
}
